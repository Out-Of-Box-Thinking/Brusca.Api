{
  "Brusca": {
    "DatabaseConnectionString": "Server=.;Database=BruscaDb;Trusted_Connection=True;TrustServerCertificate=True;Encrypt=True;",

    "Auth": {
      "Mode": "Local",
      "Jwt": {
        "Issuer": "https://brusca.internal",
        "Audience": "brusca-api",
        "SecretKey": "REPLACE_WITH_SECRET_IN_USER_SECRETS_OR_ENV",
        "ExpiryMinutes": 480
      },
      "AzureAd": {
        "TenantId": "",
        "ClientId": "",
        "Instance": "https://login.microsoftonline.com/"
      }
    },

    "Cors": {
      "AllowedOrigins": [ "http://localhost:4321", "http://localhost:3000" ]
    },

    "Logging": {
      "Audit": {
        "Sink": "Both",
        "MinimumLevel": "Information",
        "FilePath": "logs/audit/audit-.json",
        "ElasticsearchUri": "http://localhost:9200",
        "ElasticsearchIndexFormat": "brusca-audit-{0:yyyy.MM}"
      },
      "Error": {
        "Sink": "Both",
        "MinimumLevel": "Warning",
        "FilePath": "logs/error/error-.json",
        "ElasticsearchUri": "http://localhost:9200",
        "ElasticsearchIndexFormat": "brusca-error-{0:yyyy.MM}"
      }
    },

    "Claude": {
      "ApiKey": "REPLACE_WITH_API_KEY_IN_USER_SECRETS_OR_ENV",
      "Model": "claude-opus-4-5",
      "MaxTokens": 4096
    },

    "FileSystem": {
      "MaxDepth": 20,
      "MaxFileSizeBytes": 10485760,
      "IgnoredDirectories": [ ".git", "node_modules", "bin", "obj", ".vs", "__pycache__" ]
    }
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Brusca": "Information"
      }
    }
  },

  "AllowedHosts": "*"
}
