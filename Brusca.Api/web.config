<?xml version="1.0" encoding="utf-8"?>
<!--
  web.config — IIS hosting for Brusca.Api (ASP.NET Core 9, in-process model)

  IMPORTANT:
  - The aspNetCore module requires the ASP.NET Core Hosting Bundle to be installed on the IIS server.
  - Set ASPNETCORE_ENVIRONMENT to "Production" via IIS Manager or this file.
  - Never store secrets (API keys, passwords) in this file. Use IIS environment variables
    or Windows DPAPI-protected configuration instead. See SetupGuide.md.
-->
<configuration>
  <system.webServer>
    <handlers>
      <add name="aspNetCore"
           path="*"
           verb="*"
           modules="AspNetCoreModuleV2"
           resourceType="Unspecified" />
    </handlers>

    <aspNetCore processPath="dotnet"
                arguments=".\Brusca.Api.dll"
                stdoutLogEnabled="true"
                stdoutLogFile=".\logs\stdout"
                hostingModel="inprocess">
      <environmentVariables>
        <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
        <!--
          Sensitive values should NOT be set here in plain text.
          Use IIS Manager > Application Pool > Advanced Settings > Environment Variables,
          or set them as Windows system environment variables on the server.

          Required variables (set outside this file):
            Brusca__Auth__Jwt__SecretKey
            Brusca__Claude__ApiKey
            Brusca__DatabaseConnectionString
        -->
      </environmentVariables>
    </aspNetCore>

    <!-- Security headers -->
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="DENY" />
        <add name="X-XSS-Protection" value="1; mode=block" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
      </customHeaders>
    </httpProtocol>

    <!-- Prevent IIS from serving static files from the publish folder directly -->
    <staticContent>
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
    </staticContent>

    <!-- Request filtering -->
    <security>
      <requestFiltering>
        <!-- Increase for large file path payloads if needed -->
        <requestLimits maxAllowedContentLength="10485760" />
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
